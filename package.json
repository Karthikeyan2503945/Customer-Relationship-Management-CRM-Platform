{
  "name": "crm360",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=client && npm install --workspace=server",
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
